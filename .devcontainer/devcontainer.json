{
    "name": "JupyterLite Demo",
    // If we `pip install .` in the `postCreateCommand` we don't get the extensions.  Why?"
    // Either way the devcontainer image is better than plain python because we get git."
    "image": "mcr.microsoft.com/devcontainers/python:3.13",
    //  "build": {
    //     "dockerfile": "Dockerfile",
    //     "context": ".."
    // },
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "20"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python"
            }
        }
    }
    // "postCreateCommand": "pip install -e . && jupyter lite build"
}
